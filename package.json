{
  "name": "batch-rename-variants",
  "version": "1.0.1",
  "description": "Batch rename shared variant property values across multiple component sets.",
  "type": "module",
  "author": "Marius Roosendaal",
  "license": "MIT",
  "keywords": [
    "figma",
    "figma-plugin",
    "components",
    "variants",
    "batch-rename",
    "svelte",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "tsc --noEmit && eslint . --ext .ts,.js,.svelte && npx prettier --check \"src/**/*.{js,ts,svelte,html,css}\"",
    "prettier": "npx prettier --write \"src/**/*.{js,ts,svelte,html,css}\""
  },
  "dependencies": {
    "figma-plugin-utilities": "^0.3.1"
  },
  "devDependencies": {
    "rollup-plugin-visualizer": "^7.0.1",
    "@eslint/js": "^9.39.1",
    "@figma/plugin-typings": "^1.51.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.2",
    "@types/node": "^22.13.4",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^2.46.0",
    "figma-ui3-kit-svelte": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "3.7.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^4.2.20",
    "svelte-eslint-parser": "^0.39.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.2.0"
  }
}
